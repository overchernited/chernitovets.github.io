---
import Layout from "../layouts/Layout.astro";
import AboutSection from "../components/Sections/About.astro";
import Studies from "../components/Sections/Studies.astro";
import { Image } from "astro:assets";
---

<Layout>
  <main
    class="parallax overflow-hidden flex flex-col justify-center items-center mt-10"
  >
    <AboutSection />
  </main>
</Layout>

<script>
  import gsap from "gsap";

  const tl = gsap.timeline({ delay: 0.2 });

  tl.fromTo(
    ".sequence",
    { opacity: 0 },
    {
      opacity: 1,
      y: 20,
      duration: 0.5,
      stagger: 0.2,
      ease: "power2.out",
    },
  );
</script>
