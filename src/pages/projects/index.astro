---
import { getCollection, type CollectionEntry } from "astro:content";
const projects: CollectionEntry<"projects">[] = await getCollection("projects");

import ProjectCard from "../../components/ProjectCard/index.astro";
import ProjectsLayout from "../../layouts/ProjectsLayout.astro";
---

<ProjectsLayout>
  <!-- Mobile: static flex layout -->
  <div class="flex flex-wrap justify-center items-start gap-6 p-4 md:hidden">
    {
      projects.map((p) => (
        <a
          href={`/projects/${p.id}`}
          class="text-white flex flex-col justify-center items-center"
        >
          <div
            class="h-40 w-40
            text-center font-light text-white
            bg-indigo-900/20 backdrop-blur-xs rounded-xl m-5 p-2 flex justify-center items-center
            shadow-2xl"
          >
            <img src={p.data.icon} alt={`${p.data.title} image`} />
          </div>
          <div class="flex flex-col gap-5 items-center text-center">
            <h2 class="font-extrabold tracking-widest text-3xl">{p.data.title}</h2>
            <p class="tracking-widest text-xl text-wrap w-80">{p.data.description}</p>
          </div>
          <aside>
            <aside class="flex gap-2">
              {p.data.tags.map((tag: string) => (
                <span class="title">{tag}</span>
              ))}
            </aside>
          </aside>
        </a>
      ))
    }
  </div>

  <!-- Desktop: draggable board -->
  <div id="board" class="hidden md:relative md:overflow-hidden md:w-screen md:block md:h-dvh">
    {
      projects.map((p) => (
        <ProjectCard
          img={p.data.icon}
          title={p.data.title}
          description={p.data.description}
          top={p.data.top}
          left={p.data.left}
          slug={p.id}
          tags={p.data.tags}
        />
      ))
    }
  </div>
</ProjectsLayout>

<script>
  import gsap from "gsap";
  import Draggable from "gsap/Draggable";

  gsap.registerPlugin(Draggable);

  const win = window as unknown as Window & { isDesktop: boolean };

  function initDesktop(): void {
    if (!win.isDesktop) return;

    let lastX = 0;
    let lastY = 0;
    let vx = 0;
    let vy = 0;

    window.addEventListener("DOMContentLoaded", () => {
      gsap.fromTo(
        ".card",
        { scale: 0 },
        {
          scale: 1,
          duration: 0.5,
          ease: "power2.out",
          stagger: 0.1,
          delay: 0.2,
        },
      );
    });

    Draggable.create(".card", {
      type: "x,y",
      onPress: function () {
        lastX = this.x;
        lastY = this.y;
        gsap.killTweensOf(this.target);
      },
      onDrag: function () {
        vx = this.x - lastX;
        vy = this.y - lastY;
        lastX = this.x;
        lastY = this.y;
      },
      onDragEnd: function () {
        gsap.to(this.target, {
          x: `+=${vx * 5}`,
          y: `+=${vy * 5}`,
          duration: 0.8,
          ease: "power2.out",
          overwrite: "auto",
        });

        vx = 0;
        vy = 0;
      },
    });

    const cards = document.querySelectorAll(".card") as NodeListOf<HTMLElement>;

    cards.forEach((card) => {
      card.addEventListener("mouseenter", () => {
        cards.forEach((c) => {
          if (c !== card) c.style.opacity = "0.5";
        });
      });

      card.addEventListener("mouseleave", () => {
        cards.forEach((c) => {
          c.style.opacity = "1";
        });
      });
    });
  }

  if (win.isDesktop !== undefined) {
    initDesktop();
  } else {
    window.addEventListener("DOMContentLoaded", initDesktop);
  }
</script>
