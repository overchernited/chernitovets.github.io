<nav
  class="bg-indigo-950/0 rounded-full backdrop-blur-2xl z-100 fixed flex justify-center items-center w-full"
>
  <div class="hidden md:flex items-center gap-20 m-2">
    <a href="/" class="navbar-link">MaHe</a>
    <a href=`${import.meta.env.BASE_URL}about` class="navbar-link">About</a>
    <a href=`${import.meta.env.BASE_URL}appearances` class="navbar-link"
      >Appearances</a
    >
    <a href=`${import.meta.env.BASE_URL}projects` class="navbar-link"
      >Projects</a
    >
    <a href=`${import.meta.env.BASE_URL}technologies` class="navbar-link"
      >Technologies</a
    >
  </div>
</nav>

<button
  id="hamburger-btn"
  class="backdrop-blur-3xl m-2 rounded-full md:hidden fixed top-4 right-4 z-150 flex flex-col gap-1.5 p-2 cursor-pointer"
>
  <span
    id="ham-line-1"
    class="block w-7 h-0.5 bg-gray-300 transition-all duration-300 origin-center"
  ></span>
  <span
    id="ham-line-2"
    class="block w-7 h-0.5 bg-gray-300 transition-all duration-300 origin-center"
  ></span>
  <span
    id="ham-line-3"
    class="block w-7 h-0.5 bg-gray-300 transition-all duration-300 origin-center"
  ></span>
</button>

<div
  id="mobile-menu"
  class="fixed inset-0 z-120 bg-indigo-950/30 backdrop-blur-2xl flex flex-col items-center justify-center gap-8 translate-x-full transition-transform duration-300 md:hidden"
>
  <a
    href=`${import.meta.env.BASE_URL}about`
    class="navbar-link text-2xl"
    onclick="closeMenu()">About</a
  >
  <a
    href=`${import.meta.env.BASE_URL}appearances`
    class="navbar-link text-2xl"
    onclick="closeMenu()">Appearances</a
  >
  <a
    href=`${import.meta.env.BASE_URL}projects`
    class="navbar-link text-2xl"
    onclick="closeMenu()">Projects</a
  >
  <a
    href=`${import.meta.env.BASE_URL}technologies`
    class="navbar-link text-2xl"
    onclick="closeMenu()">Technologies</a
  >
</div>

<script>
  declare global {
    interface Window {
      closeMenu: () => void;
    }
  }

  import gsap from "gsap";

  gsap.from(".navbar-link", {
    opacity: 0,
    y: 30,
    duration: 0.8,
    stagger: 0.05,
    ease: "power2.out",
    transformOrigin: "center",
  });

  const btn = document.getElementById("hamburger-btn");
  const menu = document.getElementById("mobile-menu");
  const line1 = document.getElementById("ham-line-1");
  const line2 = document.getElementById("ham-line-2");
  const line3 = document.getElementById("ham-line-3");

  function closeMenu() {
    menu?.classList.add("translate-x-full");
    line1?.classList.remove("rotate-45", "translate-y-[8px]");
    line2?.classList.remove("opacity-0");
    line3?.classList.remove("-rotate-45", "-translate-y-[8px]");
  }

  function openMenu() {
    menu?.classList.remove("translate-x-full");
    line1?.classList.add("rotate-45", "translate-y-[8px]");
    line2?.classList.add("opacity-0");
    line3?.classList.add("-rotate-45", "-translate-y-[8px]");
  }

  window.closeMenu = closeMenu;

  if (btn && menu && line1 && line2 && line3) {
    btn.addEventListener("click", () => {
      const isOpen = !menu.classList.contains("translate-x-full");
      isOpen ? closeMenu() : openMenu();
    });
  }
</script>
