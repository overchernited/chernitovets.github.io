---
import Image from "astro/components/Image.astro";

interface ProjectCard {
  title: string;
  top: number;
  left: number;
  img: string;
  description: string;
  slug: any;
  tags: string[];
}

const { description, img, title, top, left, slug, tags } = Astro.props;
---

<a
  href={`/projects/${slug}`}
  style={`top: ${top}px; left: ${left}px;`}
  ondblclick=`alert("helo")`
  class="scale-0 card absolute text-white flex flex-col justify-center items-center
    transition-opacity duration-250"
>
  <div
    class="h-40 w-40
    text-center font-light text-white
    bg-indigo-900/20 backdrop-blur-xs rounded-xl m-5 p-2 flex justify-center items-center
    shadow-2xl"
  >
    <img src={img} alt={`${title} image`} />
  </div>
  <div class="flex flex-col gap-5 items-center text-center">
    <h2 class="font-extrabold tracking-widest text-3xl">{title}</h2>
    <p class="tracking-widest text-xl text-wrap w-80">{description}</p>
  </div>
  <aside>
    <aside class="flex gap-2">
      {tags.map((tag: string) => (
        <span class="title">{tag}</span>
      ))}
    </aside>
  </aside>
</a>
