---
import Navbar from "../components/Navbar/index.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="MyWebSite" />
    <link rel="manifest" href="/site.webmanifest" />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <title>Marlon</title>
  </head>
  <body>
    <Navbar />
    <slot />

    <footer
      class="p-2 w-full text-white flex gap-5 justify-center items-center flex-col"
    >
      <p class="font-bold title">Marlon Hernández 2026</p>
      <div class="*:hover:underline">
        <a href=`${import.meta.env.BASE_URL}about`>About</a>
        <a href=`${import.meta.env.BASE_URL}appearances`>Appearances</a>
        <a href=`${import.meta.env.BASE_URL}projects`>Projects</a>
        <a href=`${import.meta.env.BASE_URL}technologies`>Technologies</a>
      </div>
      <div class="*:hover:underline">
        <a>github</a>
        <a>cv</a>
        <a>linkedin</a>
        <a>gmail</a>
      </div>
    </footer>
  </body>
</html>

<script>
  import gsap from "gsap";

  gsap.to(".title", {
    backgroundPosition: "100% center",
    duration: 1,
    repeat: -1,
    ease: "none",
    yoyo: true,
  });

  const win = window as unknown as Window & { isDesktop: boolean };
  const mql = window.matchMedia("(min-width: 768px)");

  function onMouseMove(e: MouseEvent): void {
    const el = document.querySelector(".parallax");
    if (!el) return;
    const x = (e.clientX / window.innerWidth - 0.5) * 80;
    const y = (e.clientY / window.innerHeight - 0.5) * 40;
    gsap.to(el, { x, y, duration: 0.6, ease: "power2.out" });
  }

  function setDesktop(isDesktop: boolean): void {
    win.isDesktop = isDesktop;
    if (isDesktop) {
      window.addEventListener("mousemove", onMouseMove);
    } else {
      window.removeEventListener("mousemove", onMouseMove);
    }
  }

  function onDesktopChange(e: MediaQueryListEvent): void {
    setDesktop(e.matches);
  }

  setDesktop(mql.matches);
  mql.addEventListener("change", onDesktopChange);
</script>
